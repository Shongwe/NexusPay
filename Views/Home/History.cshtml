@model IEnumerable<NexusPay.Models.Transaction>

@{
    ViewData["Title"] = "Transaction History";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Audit Log</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Enterprise Audit Trail</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Reference</th>
                        <th>Type</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model)
                    {
                        <tr>
                            <td>@tx.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><code class="text-uppercase">@tx.Reference</code></td>
                            <td><span class="badge bg-secondary">@tx.Type</span></td>
                            <td class="text-end @(tx.Amount > 0 ? "text-success" : "text-danger")">
                                R @tx.Amount.ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>