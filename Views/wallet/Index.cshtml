@model IEnumerable<NexusPay.Models.Account>

@{
    ViewData["Title"] = "My Accounts";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-wallet2"></i> NexusPay Dashboard</h2>
        <a asp-action="Transfer" class="btn btn-success">
            <i class="bi bi-arrow-left-right"></i> New Transfer
        </a>
    </div>

    <div class="row">
        @foreach (var account in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-muted">Account: @account.AccountNumber</h5>
                        <h3 class="card-text text-dark">R @account.Balance.ToString("N2")</h3>
                        <p class="badge bg-info text-wrap">Active Status</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="History" asp-route-id="@account.Id" class="btn btn-sm btn-outline-primary">View History</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>